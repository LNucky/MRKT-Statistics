# Скопируй этот файл как `.env` и подставь значения.
#
# Токен MRKT — один из вариантов:
# (1) MRKT_ACCESS_TOKEN из браузера (DevTools → api.tgmrkt.io → Authorization / cookie access_token)
# (2) TELEGRAM_API_ID + TELEGRAM_API_HASH — скрапер сам получает токен (mrkt_auth); MRKT_ACCESS_TOKEN можно не задавать

MRKT_ACCESS_TOKEN=

# Автовыдача токена для scraper.py / auth_mrkt.py (https://my.telegram.org/apps)
# TELEGRAM_API_ID=
# TELEGRAM_API_HASH=
# Файл сессии: OUTPUT_DIR / TELEGRAM_SESSION_NAME.session (в Docker том обычно ./data)
# TELEGRAM_SESSION_NAME=mrkt_auth_session
# Полностью без интерактива в Docker: экспорт строки сессии Pyrogram (секрет!)
# TELEGRAM_SESSION_STRING=

# Каждые N страниц ленты — заново получить MRKT токен (только если заданы TELEGRAM_*). 0 = только при старте.
# MRKT_AUTH_REFRESH_PAGES=1000

# 0 = не печатать каждый listing в stdout (рекомендуется в Docker при длинной выгрузке)
# MRKT_LOG_LISTINGS=1

# Каждые N страниц — чекпоинт на диск (0 = только при старте/ошибке). По умолчанию в коде 100.
# MRKT_CHECKPOINT_PAGES=100

# Один запуск: продолжить с существующего feed.json (resume_cursor в meta). После успешной докачки убрать.
# MRKT_RESUME=1

# Опционально: каталог для feed.json (в Docker задай /data и смонтируй том на ./data)
# OUTPUT_DIR=

# Только для docker compose build: uid/gid пользователя в образе (= кто пишет в /data).
# Должны совпадать с владельцем каталога ./data на хосте. По умолчанию в compose 1000:1000.
# APP_UID=1000
# APP_GID=1000
