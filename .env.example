# Скопируй этот файл как `.env` и подставь значения.
# Токен из браузера: DevTools → Network → запрос к api.tgmrkt.io → заголовок Authorization
# или cookie access_token для origin cdn.tgmrkt.io

MRKT_ACCESS_TOKEN=

# Опционально: каталог для feed.json (в Docker задай /data и смонтируй том на ./data)
# OUTPUT_DIR=
